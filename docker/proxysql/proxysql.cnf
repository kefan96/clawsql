datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="admin:admin;radmin:radmin"
    mysql_ifaces="0.0.0.0:6032"
    refresh_interval=2000
    web_enabled=true
    web_port=6080
    stats_history_duration=86400
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    interfaces="0.0.0.0:6033"
    default_schema="information_schema"
    stacksize=1048576
    server_version="8.0.0"
    connect_timeout_server=3000
    monitor_username="clawsql_monitor"
    monitor_password="monitorpassword"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

mysql_servers=
{
    {
        address="mysql-primary"
        port=3306
        hostgroup_id=10
        max_connections=100
        weight=1
    },
    {
        address="mysql-replica-1"
        port=3306
        hostgroup_id=20
        max_connections=100
        weight=1
    },
    {
        address="mysql-replica-2"
        port=3306
        hostgroup_id=20
        max_connections=100
        weight=1
    }
}

mysql_users=
{
    {
        username="root"
        password="rootpassword"
        default_hostgroup=10
        transaction_persistent=true
    },
    {
        username="app"
        password="apppassword"
        default_hostgroup=10
        transaction_persistent=true
    }
}

mysql_query_rules=
{
    {
        rule_id=1
        active=1
        match_pattern="^SELECT"
        destination_hostgroup=20
        apply=1
    },
    {
        rule_id=2
        active=1
        match_pattern="^SELECT.*FOR UPDATE"
        destination_hostgroup=10
        apply=1
    }
}

scheduler=
{
    enabled=false
}

mysql_replication_hostgroups=
{
    {
        writer_hostgroup=10
        reader_hostgroup=20
        comment="clawsql cluster"
    }
}