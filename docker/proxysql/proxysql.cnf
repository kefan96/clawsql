# ClawSQL ProxySQL Configuration
# This is an empty configuration - servers are added dynamically via ClawSQL API
#
# When you register MySQL instances with ClawSQL, they will be automatically
# added to ProxySQL for read/write splitting and load balancing.

datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="admin:admin;clawsql:clawsql"
    mysql_ifaces="0.0.0.0:6032"
    refresh_interval=2000
    web_enabled=true
    web_port=6080
    stats_history_duration=86400
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    interfaces="0.0.0.0:6033"
    default_schema="information_schema"
    stacksize=1048576
    server_version="8.0.0"
    connect_timeout_server=3000
    # Default monitor credentials - override via ClawSQL API when registering instances
    monitor_username="monitor"
    monitor_password="monitor"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

# No hardcoded servers - configured dynamically via ClawSQL API
mysql_servers=
{
}

# No hardcoded users - configured dynamically via ClawSQL API
mysql_users=
{
}

# Default query rules for read/write splitting
# Rule 1: SELECT queries go to reader hostgroup (20)
# Rule 2: SELECT ... FOR UPDATE goes to writer hostgroup (10)
# Rule 100: All other queries go to writer hostgroup (10)
mysql_query_rules=
{
    {
        rule_id=1
        active=1
        match_pattern="^SELECT.*FOR UPDATE"
        destination_hostgroup=10
        apply=1
    },
    {
        rule_id=2
        active=1
        match_pattern="^SELECT"
        destination_hostgroup=20
        apply=1
    },
    {
        rule_id=100
        active=1
        match_pattern=".*"
        destination_hostgroup=10
        apply=1
    }
}

scheduler=
{
    enabled=false
}

# Replication hostgroups for automatic read/write splitting
# Writer hostgroup: 10
# Reader hostgroup: 20
mysql_replication_hostgroups=
{
    {
        writer_hostgroup=10
        reader_hostgroup=20
        comment="clawsql managed cluster"
    }
}