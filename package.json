{
  "name": "clawsql",
  "version": "0.1.0",
  "description": "MySQL Cluster Automation and Operations Management System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawsql": "./dist/bin/clawsql.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mysql",
    "cluster",
    "automation",
    "orchestrator",
    "proxysql",
    "monitoring",
    "failover"
  ],
  "author": "ClawSQL Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.1",
    "axios": "^1.7.2",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^5.0.0",
    "mysql2": "^3.11.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clawsql/clawsql"
  }
}