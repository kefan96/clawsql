# ClawSQL Configuration Template
# Copy this file to .env and customize for your environment

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_TOKEN_SECRET=your-secret-key-change-in-production
API_TOKEN_EXPIRY_HOURS=24

# =============================================================================
# Database Configuration (ClawSQL internal state)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clawsql
DB_USER=clawsql
DB_PASSWORD=clawsql_password
DB_POOL_SIZE=10

# =============================================================================
# Orchestrator Configuration
# =============================================================================
ORCHESTRATOR_URL=http://orchestrator:3000
ORCHESTRATOR_TIMEOUT=30.0
ORCHESTRATOR_TLS_ENABLED=false
ORCHESTRATOR_TLS_CERT=
ORCHESTRATOR_TLS_KEY=

# =============================================================================
# ProxySQL Configuration
# =============================================================================
PROXYSQL_HOST=proxysql
PROXYSQL_ADMIN_PORT=6032
PROXYSQL_MYSQL_PORT=6033
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin

# =============================================================================
# Prometheus Configuration
# =============================================================================
PROMETHEUS_URL=http://prometheus:9090
METRICS_RETENTION_DAYS=15

# =============================================================================
# Monitoring Settings
# =============================================================================
COLLECTION_INTERVAL=15.0
HEALTH_CHECK_INTERVAL=10.0
ALERT_COOLDOWN_MINUTES=5

# =============================================================================
# Failover Settings
# =============================================================================
AUTO_FAILOVER_ENABLED=true
FAILOVER_TIMEOUT_SECONDS=30
MIN_REPLICAS_FOR_FAILOVER=2
CONFIRMATION_CHECKS=3

# =============================================================================
# Discovery Settings
# =============================================================================
DISCOVERY_NETWORK_SEGMENTS=172.18.0.0/24
DISCOVERY_PORT_RANGE_START=3306
DISCOVERY_PORT_RANGE_END=3306
DISCOVERY_TIMEOUT=2.0
DISCOVERY_MAX_CONCURRENT=100

# =============================================================================
# MySQL Connection Credentials
# =============================================================================
MYSQL_MONITOR_USER=monitor
MYSQL_MONITOR_PASSWORD=monitor_password
MYSQL_REPLICATION_USER=repl
MYSQL_REPLICATION_PASSWORD=repl_password

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# TLS Configuration (optional)
# =============================================================================
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=